# macOS Finder metadata is always local machine noise and should never be committed.
.DS_Store
**/.DS_Store

# Keep local preview exports out of git while preserving documented artifact folders.
artifacts/*
!artifacts/README.md
!artifacts/headless-regression/

# Keep generated App web bundles out of git; native shells should sync from fresh output.
dist/

# Keep local Python cache artifacts out of git; resource generation scripts may emit them during local runs.
__pycache__/
**/__pycache__/
*.pyc

artifacts/headless-regression/*
!artifacts/headless-regression/.gitkeep
